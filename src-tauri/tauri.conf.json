{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Launched",
  "version": "1.1.5",
  "identifier": "com.infuseting.launched",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Launched",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Infuseting/launched/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3MjdEMUM1RkUwOTk2M0QKUldROWxnbit4ZEVubDR1R0EzcjNkSjNDckxYU1g3enRUQmhteWVJLzhzNXJHU0R0ekgxdExYVHoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Infuseting",
    "copyright": "Infuseting",
    "shortDescription": "Launcher de différents serveur RP",
    "license": "MIT",
    "category": "Game",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}